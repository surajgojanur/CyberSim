# CyberSim local defaults
NODE_ENV=development
SERVER_HOST=0.0.0.0
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
DATABASE_PATH=server/data/cybersim.db
AUTH_SECRET=dev-only-change-me
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin123
SERVE_CLIENT=false

# Optional for split frontend/backend deployments. Leave unset for the
# same-origin Vite proxy in development and Express hosting in production.
# VITE_API_URL=http://localhost:4000
# VITE_SOCKET_URL=http://localhost:4000

# For single-process production hosting after `npm run build`, set:
# NODE_ENV=production
# CLIENT_ORIGIN=https://your-cybersim-host.example
# AUTH_SECRET=replace-with-a-long-random-secret
# SERVE_CLIENT=true
